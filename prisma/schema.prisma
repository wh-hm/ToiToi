// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. ユーザマスタ (users)
model User {
  id              String            @id @db.VarChar(255) // UUID
  google_id       String            @unique @db.VarChar(255)
  username        String?            @db.VarChar(50)
  created_at      DateTime          @default(now()) @db.Timestamp
  delete_flag     Int               @default(0)
  email           String?            @db.VarChar(255) // phase2で必要
  updated_at      DateTime?          @default(now()) @updatedAt @db.Timestamp

  // リレーション関係
  spaces           Space[]
  loginManagement  LoginManagement?
  goal             Goal?

  @@map("users")
}

// 2. スペースマスタ (spaces)
model Space {
  id           Int            @id @default(autoincrement()) // SERIAL
  user_id      String            @db.VarChar(255)
  name         String            @db.VarChar(255)
  created_at   DateTime         @default(now()) @db.Timestamp
  delete_flag  Int              @default(0)
  space_type   Int               @default(0)
  favorite_flag Int?             @default(0)
  updated_at  DateTime?         @default(now()) @updatedAt @db.Timestamp
  is_archived  Int              @default(0)
  // 外部キーとの紐付け
  user         User              @relation(fields: [user_id], references: [id])
  
  // リレーション関係
  chats         Chat[]
  tasks            Task[]
  questions        Question[]

  @@map("spaces")
}

// 3. チャットマスタ (chats)
model Chat {
  id            Int      @id @default(autoincrement()) // SERIAL
  space_id      Int      
  user_id       String   @db.VarChar(255)
  message       String?   @db.VarChar(255)
  image_url     String?  @db.VarChar(255)
  created_at    DateTime @default(now()) @db.Timestamp
  delete_flag   Int?      @default(0)
  favorite_flag Int?      @default(0)
  stamp         String?   @db.VarChar(255)
  background    Int?      @default(0)
   updated_at  DateTime?  

  // 外部キーとの紐付け
  space         Space    @relation(fields: [space_id], references: [id])

  @@map("chats")
}

// 4. タスクマスタ (tasks)
model Task {
  id          Int       @id @default(autoincrement()) // SERIAL
  user_id     String    @db.VarChar(255)
  title       String    @db.VarChar(255)
  due_date    DateTime  @db.Date
  status      Int       @default(0)
  created_at  DateTime?  @default(now()) @db.Timestamp
  delete_flag Int?       @default(0)
  space_id    Int      
  tag         Int       @default(0)
  updated_at  DateTime? @default(now()) @updatedAt @db.Timestamp
  description String?   @db.VarChar(255)
  is_allday   Int       @default(0)
  priority    Int       @default(0)
  // 外部キーとの紐付け
  space       Space     @relation(fields: [space_id], references: [id])

  @@map("tasks")
}

// 5. 質問マスタ (questions)
model Question {
  id          Int       @id @default(autoincrement()) // SERIAL
  space_id    Int       
  title       String    @db.VarChar(255)
  is_resolved Int       @default(0)
  created_at  DateTime?  @default(now()) @db.Timestamp
  delete_flag Int       @default(0)
  user_id     String    @db.VarChar(255)
  question    String    @db.VarChar(255)
  tag         Int?      @default(0)
  updated_at  DateTime? @default(now()) @updatedAt @db.Timestamp

  // 外部キーとの紐付け
  space       Space     @relation(fields: [space_id], references: [id])
  
  // リレーション関係
  questionChats QuestionChats[]

  @@map("questions")
}

// 6. 質問チャットマスタ (question_chats)
model QuestionChats {
  id          Int      @id @default(autoincrement()) // SERIAL
  question_id Int      
  user_id     String   @db.VarChar(255)
  message     String?   @db.VarChar(255)
  created_at  DateTime @default(now()) @db.Timestamp
  delete_flag Int      @default(0)
  image_url   String?  @db.VarChar(255)
  stamp       String?  @db.VarChar(255)
  updated_at  DateTime?  
  nice_flag   Int?      @default(0)

  // 外部キーとの紐付け
  question    Question @relation(fields: [question_id], references: [id])

  @@map("question_chats")
}

// 7. ログイン管理マスタ (login_management)
model LoginManagement {
  user_id          String   @id @db.VarChar(255) // PKかつFK
  last_login_at    DateTime @default(now()) @updatedAt @db.Timestamp
  total_login_days Int      @default(1)
  current_streak   Int      @default(1)
  delete_flag      Int      @default(0)
  

  // 外部キーとの紐付け
  user             User     @relation(fields: [user_id], references: [id])

  @@map("login_management")
}


// 8. 目標管理マスタ (goal)
model Goal {
  id          String    @id @db.VarChar(255) // ユーザーID (PKかつFK)
  content     String?    @db.VarChar(255)
  created_at  DateTime  @default(now()) @db.Timestamp
  deleted_at  DateTime  @db.Timestamp
  status      Int       @default(0)
  delete_flag Int?      @default(0)

  // 外部キーとの紐付け
  user        User      @relation(fields: [id], references: [id])

  @@map("goal")
}